import pygame


def main():
    pygame.init()

    # Window settings
    WIDTH, HEIGHT = 1000, 700
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    pygame.display.set_caption("Simple Paint")

    clock = pygame.time.Clock()

    # Background color of the canvas
    BG_COLOR = (255, 255, 255)

    # Fill screen once at the start
    screen.fill(BG_COLOR)

    # Current drawing settings
    current_color = (0, 0, 255)   # default = blue
    brush_radius = 8
    tool = "brush"                # brush, rect, circle, eraser

    # For free drawing
    drawing = False
    last_pos = None

    # For shape drawing preview
    start_pos = None
    canvas = screen.copy()        # stores already drawn content

    # Font for tool/color info
    font = pygame.font.SysFont("arial", 22)

    running = True
    while running:
        pressed = pygame.key.get_pressed()

        alt_held = pressed[pygame.K_LALT] or pressed[pygame.K_RALT]
        ctrl_held = pressed[pygame.K_LCTRL] or pressed[pygame.K_RCTRL]

        for event in pygame.event.get():
            # Quit actions
            if event.type == pygame.QUIT:
                running = False

            if event.type == pygame.KEYDOWN:
                # Exit hotkeys
                if event.key == pygame.K_w and ctrl_held:
                    running = False
                elif event.key == pygame.K_F4 and alt_held:
                    running = False
                elif event.key == pygame.K_ESCAPE:
                    running = False

                # -----------------------------
                # Tool selection
                # -----------------------------
                elif event.key == pygame.K_1:
                    tool = "brush"
                elif event.key == pygame.K_2:
                    tool = "rect"
                elif event.key == pygame.K_3:
                    tool = "circle"
                elif event.key == pygame.K_4:
                    tool = "eraser"

                # -----------------------------
                # Color selection
                # -----------------------------
                elif event.key == pygame.K_r:
                    current_color = (255, 0, 0)      # red
                elif event.key == pygame.K_g:
                    current_color = (0, 255, 0)      # green
                elif event.key == pygame.K_b:
                    current_color = (0, 0, 255)      # blue
                elif event.key == pygame.K_k:
                    current_color = (0, 0, 0)        # black
                elif event.key == pygame.K_y:
                    current_color = (255, 255, 0)    # yellow
                elif event.key == pygame.K_p:
                    current_color = (255, 0, 255)    # pink
                elif event.key == pygame.K_c:
                    current_color = (0, 255, 255)    # cyan

                # Clear whole screen
                elif event.key == pygame.K_SPACE:
                    screen.fill(BG_COLOR)
                    canvas = screen.copy()

            # Mouse wheel / buttons for changing brush size
            if event.type == pygame.MOUSEBUTTONDOWN:
                # Left click starts drawing
                if event.button == 1:
                    drawing = True
                    start_pos = event.pos
                    last_pos = event.pos

                    # Save current screen before previewing shapes
                    canvas = screen.copy()

                    # If brush or eraser, draw immediately at click point
                    if tool == "brush":
                        pygame.draw.circle(screen, current_color, event.pos, brush_radius)
                    elif tool == "eraser":
                        pygame.draw.circle(screen, BG_COLOR, event.pos, brush_radius)

                # Mouse wheel up -> increase size
                elif event.button == 4:
                    brush_radius = min(100, brush_radius + 1)

                # Mouse wheel down -> decrease size
                elif event.button == 5:
                    brush_radius = max(1, brush_radius - 1)

                # Right click can also decrease size
                elif event.button == 3:
                    brush_radius = max(1, brush_radius - 1)

            # Mouse released -> finish current drawing/shape
            if event.type == pygame.MOUSEBUTTONUP:
                if event.button == 1 and drawing:
                    end_pos = event.pos

                    # Finalize rectangle
                    if tool == "rect":
                        screen.blit(canvas, (0, 0))
                        rect = make_rect(start_pos, end_pos)
                        pygame.draw.rect(screen, current_color, rect, 2)

                    # Finalize circle
                    elif tool == "circle":
                        screen.blit(canvas, (0, 0))
                        center, radius = make_circle_data(start_pos, end_pos)
                        if radius > 0:
                            pygame.draw.circle(screen, current_color, center, radius, 2)

                    # Save final result after shape is placed
                    canvas = screen.copy()
                    drawing = False
                    start_pos = None
                    last_pos = None

            # Mouse movement
            if event.type == pygame.MOUSEMOTION:
                if drawing:
                    current_pos = event.pos

                    # Free brush drawing
                    if tool == "brush":
                        draw_line(screen, current_color, last_pos, current_pos, brush_radius)
                        last_pos = current_pos

                    # Eraser works like brush but with background color
                    elif tool == "eraser":
                        draw_line(screen, BG_COLOR, last_pos, current_pos, brush_radius)
                        last_pos = current_pos

                    # Rectangle preview while dragging
                    elif tool == "rect":
                        screen.blit(canvas, (0, 0))
                        rect = make_rect(start_pos, current_pos)
                        pygame.draw.rect(screen, current_color, rect, 2)

                    # Circle preview while dragging
                    elif tool == "circle":
                        screen.blit(canvas, (0, 0))
                        center, radius = make_circle_data(start_pos, current_pos)
                        if radius > 0:
                            pygame.draw.circle(screen, current_color, center, radius, 2)

        # Draw small UI text each frame
        draw_ui(screen, font, tool, current_color, brush_radius)

        pygame.display.flip()
        clock.tick(60)

    pygame.quit()


def draw_line(screen, color, start, end, radius):
    """
    Draws a smooth thick line by placing circles between two points.
    This is useful for brush/eraser so there are no gaps.
    """
    if start is None or end is None:
        return

    dx = end[0] - start[0]
    dy = end[1] - start[1]
    distance = max(abs(dx), abs(dy))

    # If mouse barely moved, draw just one circle
    if distance == 0:
        pygame.draw.circle(screen, color, start, radius)
        return

    for i in range(distance + 1):
        x = int(start[0] + dx * i / distance)
        y = int(start[1] + dy * i / distance)
        pygame.draw.circle(screen, color, (x, y), radius)


def make_rect(start, end):
    """
    Creates a pygame.Rect no matter in which direction the mouse was dragged.
    """
    x1, y1 = start
    x2, y2 = end

    left = min(x1, x2)
    top = min(y1, y2)
    width = abs(x1 - x2)
    height = abs(y1 - y2)

    return pygame.Rect(left, top, width, height)


def make_circle_data(start, end):
    """
    Uses start point as the center of the circle.
    Radius is the distance from center to current mouse position.
    """
    cx, cy = start
    ex, ey = end

    radius = int(((ex - cx) ** 2 + (ey - cy) ** 2) ** 0.5)
    return (cx, cy), radius


def draw_ui(screen, font, tool, color, brush_radius):
    """
    Draws simple information panel at the top of the window.
    """
    # Background for UI bar
    pygame.draw.rect(screen, (230, 230, 230), (0, 0, screen.get_width(), 40))

    tool_text = f"Tool: {tool}"
    size_text = f"Size: {brush_radius}"
    color_text = f"Color: {color}"

    text_surface = font.render(
        tool_text + "   |   " + size_text + "   |   " + color_text,
        True,
        (0, 0, 0)
    )
    screen.blit(text_surface, (10, 10))

    # Small current-color preview box
    pygame.draw.rect(screen, color, (750, 8, 24, 24))
    pygame.draw.rect(screen, (0, 0, 0), (750, 8, 24, 24), 2)


main()